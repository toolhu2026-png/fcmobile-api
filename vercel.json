{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/check_key(.*)", "dest": "/api/check_key.js$1" },
    { "src": "/admin(.*)", "dest": "/api/admin.js$1" }
  ],
  "functions": {
    "api/check_key.js": { "maxDuration": 30 },
    "api/validate.js": { "maxDuration": 30 },
    "api/admin.js": { "maxDuration": 30 }
  }
}
